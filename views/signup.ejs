<!DOCTYPE html>
<html>
  
  <%- include('partials/head.ejs') %>
  <title>Mixify</title>
  <body class="verticalAlign">

    <div class="logo" style="width: 400px">
      <img src="img/Untitled-1.gif" width="100%">
    </div>

    <div class="card" id="loginCard">
      <div class="card-body">
        
        <form action="/addUser" method="POST">
          <h1>Sign-Up</h1>
          <div class="input-group flex-nowrap">
            <span class="input-group-text" id="addon-wrapping">@</span>
            <input type="text" name="userName" class="form-control" placeholder="Username" aria-label="Username" aria-describedby="addon-wrapping">
          </div>  
          <% if(typeof(error) != "undefined") { %>
            <% if(error == "usernameTakenError") { %>
              <div id="usernameTakenError" class="alert alert-danger form-control">That username is already taken</div>
            <% } %>
          <% } %>
          
          <div class="input-group mb-3">
            <input type="password"name = "password" class="form-control myInput" placeholder="Password" aria-label="Password" aria-describedby="button-addon2">
            <button class="btn btn-outline-light" type="button" id="button-addon2 " onclick="showPassword()">Show</button>
          </div>
              
          <div class="input-group mb-3">
            <input type="password" name="confirmed" class="form-control myInput" placeholder="Confirm password" aria-label="Password" aria-describedby="button-addon2">
            <button class="btn btn-outline-light" type="button" id="button-addon2 " onclick="showPassword()">Show</button>
          </div>
          <% if(typeof(error) != "undefined") { %>
            <% if(error == "passwordMismatch") { %>
              <div id="passwordMismatch" class="alert alert-danger form-control">Passwords do not match</div>
            <% } %>
          <% } %>
          <div class="input-group mb-3">
            <input type="email" name="email" class="form-control myInput" placeholder="Email" aria-label="Email" aria-describedby="button-addon2">
          </div>
          
      
          <button type="submit" class="btn btn-primary" class="greenToViolet">Create Account</button>
        </form>
        
        <hr class="solid">
        <span class="note">Already have an account?</span>
        <br>
        <a href="/">
          <button type="button" class="btn btn-secondary">Sign-in</button>
        </a>
      </div>
    </div>
    
  </body>
</html>